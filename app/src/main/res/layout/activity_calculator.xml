<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#111318"
    android:orientation="vertical"
    tools:context=".CalculatorActivity">

    <!-- Màn hình hiển thị kết quả -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2.5"
        android:gravity="bottom|end"
        android:orientation="vertical"
        android:padding="24dp">

        <EditText
            android:id="@+id/editFormular"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@null"
            android:gravity="end"
            android:inputType="none"
            android:text="0"
            android:textColor="@color/white"
            android:textSize="56sp"
            android:textStyle="bold" />

        <!-- Memory Buttons Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:gravity="end|center_vertical"
            android:orientation="horizontal"
            android:paddingTop="6dp">

            <TextView
                android:id="@+id/txtMC"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="#1A1D28"
                android:fontFamily="sans-serif-medium"
                android:text="@string/str_mc"
                android:textAlignment="center"
                android:textColor="#6B7496" />

            <TextView
                android:id="@+id/txtMR"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="#1A1D28"
                android:fontFamily="sans-serif-medium"
                android:text="@string/str_mr"
                android:textAlignment="center"
                android:textColor="#6B7496" />

            <TextView
                android:id="@+id/txtMPLUS"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="#1A1D28"
                android:fontFamily="sans-serif-medium"
                android:text="@string/str_m_plus"
                android:textAlignment="center"
                android:textColor="#6B7496" />

            <TextView
                android:id="@+id/txtMMINUS"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="#1A1D28"
                android:fontFamily="sans-serif-medium"
                android:text="@string/str_m_minus"
                android:textAlignment="center"
                android:textColor="#6B7496" />

            <TextView
                android:id="@+id/txtMS"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="#1A1D28"
                android:fontFamily="sans-serif-medium"
                android:text="@string/str_ms"
                android:textAlignment="center"
                android:textColor="#6B7496" />

            <TextView
                android:id="@+id/txtM"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="#1A1D28"
                android:fontFamily="sans-serif-medium"
                android:text="@string/str_m"
                android:textAlignment="center"
                android:textColor="#6B7496" />
        </LinearLayout>
    </LinearLayout>

    <!-- Bàn phím máy tính -->
    <TableLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="5"
        android:padding="8dp"
        android:stretchColumns="*">

        <!-- Hàng 1 -->
        <TableRow android:layout_weight="1">
            <Button android:layout_width="0dp" android:layout_height="match_parent" android:layout_margin="5dp" android:text="%" android:textColor="#5B82E8" android:textSize="15sp" android:backgroundTint="#161926" android:fontFamily="sans-serif-light" app:cornerRadius="14dp" />
            <Button android:layout_width="0dp" android:layout_height="match_parent" android:layout_margin="5dp" android:text="CE" android:textColor="#5B82E8" android:textSize="15sp" android:backgroundTint="#161926" android:fontFamily="sans-serif-light" app:cornerRadius="14dp" />
            <Button android:layout_width="0dp" android:layout_height="match_parent" android:layout_margin="5dp" android:text="C" android:textColor="#5B82E8" android:textSize="15sp" android:backgroundTint="#161926" android:fontFamily="sans-serif-light" app:cornerRadius="14dp" />
            <Button android:id="@+id/buttonback" android:onClick="processBackspace" android:layout_width="0dp" android:layout_height="match_parent" android:layout_margin="5dp" android:text="back" android:textColor="#5B82E8" android:textSize="15sp" android:backgroundTint="#161926" android:fontFamily="sans-serif-light" app:cornerRadius="14dp" />
        </TableRow>

        <!-- Hàng 2 -->
        <TableRow android:layout_weight="1">
            <Button android:layout_width="0dp" android:layout_height="match_parent" android:layout_margin="5dp" android:text="¹/x" android:textColor="#5B82E8" android:textSize="15sp" android:backgroundTint="#161926" android:fontFamily="sans-serif-light" app:cornerRadius="14dp" />
            <Button android:layout_width="0dp" android:layout_height="match_parent" android:layout_margin="5dp" android:text="x²" android:textColor="#5B82E8" android:textSize="15sp" android:backgroundTint="#161926" android:fontFamily="sans-serif-light" app:cornerRadius="14dp" />
            <Button android:layout_width="0dp" android:layout_height="match_parent" android:layout_margin="5dp" android:text="√x" android:textColor="#5B82E8" android:textSize="15sp" android:backgroundTint="#161926" android:fontFamily="sans-serif-light" app:cornerRadius="14dp" />
            <Button android:layout_width="0dp" android:layout_height="match_parent" android:layout_margin="5dp" android:text="÷" android:textColor="#5B82E8" android:textSize="22sp" android:backgroundTint="#1D243D" android:fontFamily="sans-serif-light" app:cornerRadius="14dp" />
        </TableRow>

        <!-- Hàng 3 -->
        <TableRow android:layout_weight="1">
            <Button android:onClick="processChooseValue" android:layout_width="0dp" android:layout_height="match_parent" android:layout_margin="5dp" android:text="7" android:textColor="#E0E0E0" android:textSize="20sp" android:backgroundTint="#161926" android:fontFamily="sans-serif-light" app:cornerRadius="14dp" />
            <Button android:onClick="processChooseValue" android:layout_width="0dp" android:layout_height="match_parent" android:layout_margin="5dp" android:text="8" android:textColor="#E0E0E0" android:textSize="20sp" android:backgroundTint="#161926" android:fontFamily="sans-serif-light" app:cornerRadius="14dp" />
            <Button android:onClick="processChooseValue" android:layout_width="0dp" android:layout_height="match_parent" android:layout_margin="5dp" android:text="9" android:textColor="#E0E0E0" android:textSize="20sp" android:backgroundTint="#161926" android:fontFamily="sans-serif-light" app:cornerRadius="14dp" />
            <Button android:layout_width="0dp" android:layout_height="match_parent" android:layout_margin="5dp" android:text="×" android:textColor="#5B82E8" android:textSize="22sp" android:backgroundTint="#1D243D" android:fontFamily="sans-serif-light" app:cornerRadius="14dp" />
        </TableRow>

        <!-- Hàng 4 -->
        <TableRow android:layout_weight="1">
            <Button android:onClick="processChooseValue" android:layout_width="0dp" android:layout_height="match_parent" android:layout_margin="5dp" android:text="4" android:textColor="#E0E0E0" android:textSize="20sp" android:backgroundTint="#161926" android:fontFamily="sans-serif-light" app:cornerRadius="14dp" />
            <Button android:onClick="processChooseValue" android:layout_width="0dp" android:layout_height="match_parent" android:layout_margin="5dp" android:text="5" android:textColor="#E0E0E0" android:textSize="20sp" android:backgroundTint="#161926" android:fontFamily="sans-serif-light" app:cornerRadius="14dp" />
            <Button android:onClick="processChooseValue" android:layout_width="0dp" android:layout_height="match_parent" android:layout_margin="5dp" android:text="6" android:textColor="#E0E0E0" android:textSize="20sp" android:backgroundTint="#161926" android:fontFamily="sans-serif-light" app:cornerRadius="14dp" />
            <Button android:layout_width="0dp" android:layout_height="match_parent" android:layout_margin="5dp" android:text="−" android:textColor="#5B82E8" android:textSize="22sp" android:backgroundTint="#1D243D" android:fontFamily="sans-serif-light" app:cornerRadius="14dp" />
        </TableRow>

        <!-- Hàng 5 -->
        <TableRow android:layout_weight="1">
            <Button android:onClick="processChooseValue" android:layout_width="0dp" android:layout_height="match_parent" android:layout_margin="5dp" android:text="1" android:textColor="#E0E0E0" android:textSize="20sp" android:backgroundTint="#161926" android:fontFamily="sans-serif-light" app:cornerRadius="14dp" />
            <Button android:onClick="processChooseValue" android:layout_width="0dp" android:layout_height="match_parent" android:layout_margin="5dp" android:text="2" android:textColor="#E0E0E0" android:textSize="20sp" android:backgroundTint="#161926" android:fontFamily="sans-serif-light" app:cornerRadius="14dp" />
            <Button android:onClick="processChooseValue" android:layout_width="0dp" android:layout_height="match_parent" android:layout_margin="5dp" android:text="3" android:textColor="#E0E0E0" android:textSize="20sp" android:backgroundTint="#161926" android:fontFamily="sans-serif-light" app:cornerRadius="14dp" />
            <Button android:layout_width="0dp" android:layout_height="match_parent" android:layout_margin="5dp" android:text="+" android:textColor="#5B82E8" android:textSize="22sp" android:backgroundTint="#1D243D" android:fontFamily="sans-serif-light" app:cornerRadius="14dp" />
        </TableRow>

        <!-- Hàng 6 -->
        <TableRow android:layout_weight="1">
            <Button android:layout_width="0dp" android:layout_height="match_parent" android:layout_margin="5dp" android:text="+/-" android:textColor="#E0E0E0" android:textSize="16sp" android:backgroundTint="#161926" android:fontFamily="sans-serif-light" app:cornerRadius="14dp" />
            <Button android:onClick="processChooseValue" android:layout_width="0dp" android:layout_height="match_parent" android:layout_margin="5dp" android:text="0" android:textColor="#E0E0E0" android:textSize="20sp" android:backgroundTint="#161926" android:fontFamily="sans-serif-light" app:cornerRadius="14dp" />
            <Button android:layout_width="0dp" android:layout_height="match_parent" android:layout_margin="5dp" android:text="." android:textColor="#E0E0E0" android:textSize="20sp" android:backgroundTint="#161926" android:fontFamily="sans-serif-light" app:cornerRadius="14dp" />
            <Button android:id="@+id/buttoncal" android:layout_width="0dp" android:layout_height="match_parent" android:layout_margin="5dp" android:text="=" android:textColor="#FFFFFF" android:textSize="24sp" android:backgroundTint="#4D7EFA" android:fontFamily="sans-serif-light" app:cornerRadius="14dp" />
        </TableRow>
    </TableLayout>

</LinearLayout>
