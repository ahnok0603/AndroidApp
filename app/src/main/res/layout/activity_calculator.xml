<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#111318"
    android:orientation="vertical"
    tools:context=".CalculatorActivity">

    <!-- Màn hình hiển thị kết quả -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:gravity="bottom"
        android:orientation="vertical"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:paddingBottom="16dp">

        <TextView
            android:id="@+id/editFormular"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@null"
            android:gravity="end"
            android:inputType="none"
            android:text="0"
            android:textColor="@color/white"
            android:textSize="56sp"
            android:textStyle="bold" />

        <!-- Memory Buttons Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:gravity="end|center_vertical"
            android:orientation="horizontal"
            android:paddingTop="6dp">

            <TextView
                android:id="@+id/txtMC"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="#1A1D28"
                android:fontFamily="sans-serif-medium"
                android:text="@string/str_mc"
                android:textAlignment="center"
                android:textColor="#6B7496" />

            <TextView
                android:id="@+id/txtMR"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="#1A1D28"
                android:fontFamily="sans-serif-medium"
                android:text="@string/str_mr"
                android:textAlignment="center"
                android:textColor="#6B7496" />

            <TextView
                android:id="@+id/txtMPLUS"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="#1A1D28"
                android:fontFamily="sans-serif-medium"
                android:text="@string/str_m_plus"
                android:textAlignment="center"
                android:textColor="#6B7496" />

            <TextView
                android:id="@+id/txtMMINUS"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="#1A1D28"
                android:fontFamily="sans-serif-medium"
                android:text="@string/str_m_minus"
                android:textAlignment="center"
                android:textColor="#6B7496" />

            <TextView
                android:id="@+id/txtMS"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="#1A1D28"
                android:fontFamily="sans-serif-medium"
                android:text="@string/str_ms"
                android:textAlignment="center"
                android:textColor="#6B7496" />

            <TextView
                android:id="@+id/txtM"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="#1A1D28"
                android:fontFamily="sans-serif-medium"
                android:text="@string/str_m"
                android:textAlignment="center"
                android:textColor="#6B7496" />
        </LinearLayout>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginBottom="8dp"
        android:background="#181D2F" />

    <!-- Bàn phím máy tính -->
    <TableLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="5"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingBottom="10dp"
        android:stretchColumns="*">
        <!-- Hàng 1: % CE C ⌫ -->
        <TableRow
            android:layout_height="0dp"
            android:layout_weight="1">

            <Button
                android:id="@+id/btnPercent"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:background="#00FFFFFF"
                android:fontFamily="sans-serif-light"
                android:stateListAnimator="@null"
                android:text="%"
                android:textColor="#5B82E8"
                android:textSize="15sp" />

            <Button
                android:id="@+id/btnCE"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:background="#00FFFFFF"
                android:fontFamily="sans-serif-light"
                android:stateListAnimator="@null"
                android:text="CE"
                android:textColor="#5B82E8"
                android:textSize="15sp" />

            <Button
                android:id="@+id/btnC"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:background="#00FFFFFF"
                android:fontFamily="sans-serif-light"
                android:stateListAnimator="@null"
                android:text="C"
                android:textColor="#5B82E8"
                android:textSize="15sp" />

            <Button
                android:id="@+id/buttonback"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_margin="5dp"
                android:layout_weight="1"
                android:background="#00FFFFFF"
                android:fontFamily="sans-serif-light"
                android:onClick="processBackspace"
                android:stateListAnimator="@null"
                android:text="Back"
                android:textColor="#5B82E8"
                android:textSize="16sp" />
        </TableRow>
        <!-- Hàng 2: 1/x x² √x ÷ -->
        <TableRow
            android:layout_height="0dp"
            android:layout_weight="1">
            <Button
                android:id="@+id/btnInverse"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:background="#00FFFFFF"
                android:fontFamily="sans-serif-light"
                android:stateListAnimator="@null"
                android:text="1/x"
                android:textColor="#5B82E8"
                android:textSize="15sp" />

            <Button
                android:id="@+id/btnSquare"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:background="#00FFFFFF"
                android:fontFamily="sans-serif-light"
                android:stateListAnimator="@null"
                android:text="x^2"
                android:textColor="#5B82E8"
                android:textSize="15sp" />

            <Button
                android:id="@+id/btnSqrt"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_margin="5dp"
                android:layout_weight="1"
                android:background="#00FFFFFF"
                android:fontFamily="sans-serif-light"
                android:stateListAnimator="@null"
                android:text="Sqrt(x)"
                android:textColor="#5B82E8"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnDivide"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_margin="5dp"
                android:layout_weight="1"
                android:background="#00FFFFFF"
                android:fontFamily="sans-serif-light"
                android:stateListAnimator="@null"
                android:text="/"
                android:textColor="#6C9AFF"
                android:textSize="22sp" />
        </TableRow>
        <!-- Hàng 3: 7 8 9 × -->
        <TableRow
            android:layout_height="0dp"
            android:layout_weight="1">
            <Button
                android:id="@+id/btn7"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:background="#00FFFFFF"
                android:fontFamily="sans-serif-light"
                android:onClick="processChooseValue"
                android:stateListAnimator="@null"
                android:text="7"
                android:textColor="#E0E0E0"
                android:textSize="20sp" />

            <Button
                android:id="@+id/btn8"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:background="#00FFFFFF"
                android:fontFamily="sans-serif-light"
                android:onClick="processChooseValue"
                android:stateListAnimator="@null"
                android:text="8"
                android:textColor="#E0E0E0"
                android:textSize="20sp" />

            <Button
                android:id="@+id/btn9"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:background="#00FFFFFF"
                android:fontFamily="sans-serif-light"
                android:onClick="processChooseValue"
                android:stateListAnimator="@null"
                android:text="9"
                android:textColor="#E0E0E0"
                android:textSize="20sp" />

            <Button
                android:id="@+id/btnMultiply"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:background="#00FFFFFF"
                android:fontFamily="sans-serif-light"
                android:stateListAnimator="@null"
                android:text="x"
                android:textColor="#6C9AFF"
                android:textSize="22sp" />
        </TableRow>
        <!-- Hàng 4: 4 5 6 − -->
        <TableRow
            android:layout_height="0dp"
            android:layout_weight="1">

            <Button
                android:id="@+id/btn4"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:background="#00FFFFFF"
                android:fontFamily="sans-serif-light"
                android:onClick="processChooseValue"
                android:stateListAnimator="@null"
                android:text="4"
                android:textColor="#E0E0E0"
                android:textSize="20sp" />

            <Button
                android:id="@+id/btn5"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_margin="5dp"
                android:layout_weight="1"
                android:background="#00FFFFFF"
                android:fontFamily="sans-serif-light"
                android:onClick="processChooseValue"
                android:stateListAnimator="@null"
                android:text="5"
                android:textColor="#E0E0E0"
                android:textSize="20sp" />

            <Button
                android:id="@+id/btn6"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:background="#00FFFFFF"
                android:fontFamily="sans-serif-light"
                android:onClick="processChooseValue"
                android:stateListAnimator="@null"
                android:text="6"
                android:textColor="#E0E0E0"
                android:textSize="20sp" />

            <Button
                android:id="@+id/btnMinus"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:background="#00FFFFFF"
                android:fontFamily="sans-serif-light"
                android:stateListAnimator="@null"
                android:text="-"
                android:textColor="#6C9AFF"
                android:textSize="22sp" />
        </TableRow>
        <!-- Hàng 5: 1 2 3 + -->
        <TableRow
            android:layout_height="0dp"
            android:layout_weight="1">

            <Button
                android:id="@+id/btn1"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:background="#00FFFFFF"
                android:fontFamily="sans-serif-light"
                android:onClick="processChooseValue"
                android:stateListAnimator="@null"
                android:text="1"
                android:textColor="#E0E0E0"
                android:textSize="20sp" />

            <Button
                android:id="@+id/btn2"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:background="#00FFFFFF"
                android:fontFamily="sans-serif-light"
                android:onClick="processChooseValue"
                android:stateListAnimator="@null"
                android:text="2"
                android:textColor="#E0E0E0"
                android:textSize="20sp" />

            <Button
                android:id="@+id/btn3"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:background="#00FFFFFF"
                android:fontFamily="sans-serif-light"
                android:onClick="processChooseValue"
                android:stateListAnimator="@null"
                android:text="3"
                android:textColor="#E0E0E0"
                android:textSize="20sp" />

            <Button
                android:id="@+id/btnPlus"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:background="#00FFFFFF"
                android:fontFamily="sans-serif-light"
                android:stateListAnimator="@null"
                android:text="+"
                android:textColor="#6C9AFF"
                android:textSize="22sp" />
        </TableRow>
        <!-- Hàng 6: +/- 0 . = -->
        <TableRow
            android:layout_height="0dp"
            android:layout_weight="1">
            <Button
                android:id="@+id/btnPositiveNegative"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:background="#00FFFFFF"
                android:fontFamily="sans-serif-light"
                android:stateListAnimator="@null"
                android:text="+/-"
                android:textColor="#E0E0E0"
                android:textSize="16sp" />

            <Button
                android:id="@+id/btn0"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:background="#00FFFFFF"
                android:fontFamily="sans-serif-light"
                android:onClick="processChooseValue"
                android:stateListAnimator="@null"
                android:text="0"
                android:textColor="#E0E0E0"
                android:textSize="20sp" />

            <Button
                android:id="@+id/btnDot"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:background="#00FFFFFF"
                android:fontFamily="sans-serif-light"
                android:stateListAnimator="@null"
                android:text="."
                android:textColor="#E0E0E0"
                android:textSize="20sp" />

            <Button
                android:id="@+id/buttoncal"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:background="#00FFFFFF"
                android:fontFamily="sans-serif-light"
                android:stateListAnimator="@null"
                android:text="="
                android:textColor="#FFFFFF"
                android:textSize="24sp" />
        </TableRow>
    </TableLayout>

</LinearLayout>